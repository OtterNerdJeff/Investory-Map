# -------------------------------------------------------
# Database (Railway PostgreSQL plugin provides this automatically)
# -------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# -------------------------------------------------------
# NextAuth (generate secret with: openssl rand -base64 32)
# NEXTAUTH_URL must match your Railway public domain exactly
# -------------------------------------------------------
NEXTAUTH_SECRET="replace-with-a-random-64-char-string"
NEXTAUTH_URL="https://your-app-name.up.railway.app"

# -------------------------------------------------------
# S3-compatible file storage (photos, signatures)
# Recommended: Cloudflare R2 (free tier, S3-compatible)
#
# For Cloudflare R2:
#   S3_ENDPOINT  = https://<account-id>.r2.cloudflarestorage.com
#   S3_REGION    = auto
#   S3_BUCKET    = investory-uploads
#   S3_ACCESS_KEY / S3_SECRET_KEY from R2 > Manage API Tokens
#
# For AWS S3:
#   S3_ENDPOINT  = (leave empty — SDK uses region-based routing)
#   S3_REGION    = ap-southeast-1
#   S3_BUCKET    = investory-uploads
#   S3_ACCESS_KEY / S3_SECRET_KEY from IAM user with S3FullAccess
# -------------------------------------------------------
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET="investory-uploads"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
